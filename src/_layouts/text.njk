---
layout: base.njk
---
<style>
  .text-page { background: var(--weiss); color: var(--dunkelgrau); min-height: 80vh; }
  .text-article { max-width: 680px; margin: 0 auto; padding: 3rem 2rem 4rem; }
  .text-back { display: inline-block; font-family: 'Raleway', sans-serif; font-weight: 300; color: var(--rosa-dunkel); text-decoration: none; margin-bottom: 2rem; opacity: 0.8; transition: opacity 0.2s; }
  .text-back:hover { opacity: 1; }
  .text-meta { display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: flex-start; margin-bottom: 2.5rem; position: relative; }
  .text-type { font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--rosa-dunkel); opacity: 0.8; width: 100%; }
  .text-date { font-size: 0.85rem; color: var(--dunkelgrau); opacity: 0.6; }
  .text-title { font-family: 'Raleway', sans-serif; font-weight: 300; font-size: clamp(1.6rem, 4vw, 2.4rem); color: var(--rosa-dunkel); margin-bottom: 1.5rem; line-height: 1.3; }
  .text-body { line-height: 2.1; color: var(--dunkelgrau); }
  .text-body p { margin-bottom: 1.4rem; }
  .text-ornament { text-align: center; color: var(--teal); opacity: 0.4; letter-spacing: 0.5em; margin: 2.5rem 0; font-size: 0.9rem; }
  .text-hero-image { margin-top: 3rem; border-radius: 8px; overflow: hidden; }
  .text-hero-image img { width: 100%; height: auto; display: block; }
  .text-lang-switch { display: flex; gap: 6px; position: absolute; right: 0; top: 0; }
  .text-lang-btn { font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.25rem 0.6rem; border-radius: 100px; border: 1px solid var(--teal); background: transparent; color: var(--teal); cursor: pointer; font-family: 'Roboto', sans-serif; transition: background 0.2s, color 0.2s; min-width: 44px; min-height: 44px; display: inline-flex; align-items: center; justify-content: center; }
  .text-lang-btn:hover { background: var(--teal); color: var(--weiss); }
  .text-lang-btn.active { background: var(--teal); color: var(--weiss); }
  .text-lang-btn:focus-visible { outline: 2px solid var(--rosa-dunkel); outline-offset: 2px; }
</style>

<div class="text-page">
<article class="text-article">
  <a href="/texte/" class="text-back">&larr; Texte</a>
  <div class="text-meta">
    <span class="text-type">{{ type }}</span>
    <span class="text-date">{{ date | readableDate }}</span>
    {% if translation_en_body %}
    <div class="text-lang-switch" role="group" aria-label="Sprache wählen">
      <button class="text-lang-btn active" data-lang="de" aria-pressed="true">DE</button>
      <button class="text-lang-btn" data-lang="en" aria-pressed="false">EN</button>
    </div>
    {% endif %}
  </div>

  <h1 class="text-title" data-lang-de="{{ title }}" data-lang-en="{{ translation_en_title or title }}">{{ title }}</h1>

  <div class="text-ornament">&#10022;</div>

  <div class="text-body" data-lang-de>{{ content | safe }}</div>
  {% if translation_en_body %}
  <div class="text-body" data-lang-en hidden>{{ translation_en_body | markdownify | safe }}</div>
  {% endif %}

  {% if heroImage %}
  <div class="text-hero-image">
    <img src="{{ heroImage }}" alt="{{ title }}">
  </div>
  {% endif %}
</article>
</div>

{% if translation_en_body %}
<script>
(function() {
  var btns = document.querySelectorAll('.text-lang-btn');
  btns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var lang = btn.dataset.lang;
      btns.forEach(function(b) {
        b.classList.toggle('active', b.dataset.lang === lang);
        b.setAttribute('aria-pressed', b.dataset.lang === lang);
      });
      document.querySelectorAll('[data-lang-de][data-lang-en]').forEach(function(el) {
        el.textContent = el.getAttribute('data-lang-' + lang);
      });
      document.querySelectorAll('.text-body[data-lang-de]').forEach(function(el) { el.hidden = lang !== 'de'; });
      document.querySelectorAll('.text-body[data-lang-en]').forEach(function(el) { el.hidden = lang !== 'en'; });
    });
  });
})();
</script>
{% endif %}
