<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | ICH BIN HIER JETZT</title>
  <meta name="description" content="{{ description | default('Doris R. Mumenthaler – Traumasensibles Coaching, Jin Shin Jyutsu, Dornach') }}">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/favicon.svg" type="image/svg+xml">
  <meta property="og:title" content="{{ title }} | ICH BIN HIER JETZT">
  <meta property="og:description" content="{{ description | default('Traumasensibles Coaching und Jin Shin Jyutsu – Doris R. Mumenthaler, Dornach') }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="ICH BIN HIER JETZT">
  <meta property="og:locale" content="de_CH">
  <color-scheme content="light only">
</head>
<body class="{{ bodyClass | default('') }}" data-cms-path="{{ page.inputPath | replace('./', '') }}">

  <nav class="main-nav">
    <button class="burger" aria-label="Menü öffnen" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul>
      <li><a href="/"{% if page.url == "/" %} class="active"{% endif %}>Willkommen</a></li>
      <li><a href="/traumasensibles-coaching/"{% if page.url == "/traumasensibles-coaching/" %} class="active"{% endif %}>Traumasensibles Coaching</a></li>
      <li><a href="/jin-shin-jyutsu/"{% if page.url == "/jin-shin-jyutsu/" %} class="active"{% endif %}>Jin Shin Jyutsu</a></li>
      <li><a href="/doris/"{% if page.url == "/doris/" %} class="active"{% endif %}>Doris R. Mumenthaler</a></li>
      <li><a href="/kosten/"{% if page.url == "/kosten/" %} class="active"{% endif %}>Energetischer Ausgleich / Kosten</a></li>
      <li><a href="/kontakt/"{% if page.url == "/kontakt/" %} class="active"{% endif %}>Kontakt</a></li>
      <li><a href="/galerie/"{% if page.url == "/galerie/" %} class="active"{% endif %}>Galerie</a></li>
      <li><a href="/texte/"{% if page.url == "/texte/" %} class="active"{% endif %}>Texte</a></li>
    </ul>
  </nav>
  <script>
    document.querySelector('.burger').addEventListener('click', function() {
      this.classList.toggle('is-open');
      this.setAttribute('aria-expanded', this.classList.contains('is-open'));
      document.querySelector('.main-nav ul').classList.toggle('is-open');
    });
  </script>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <a href="/impressum/">Impressum</a>
    <a href="/datenschutz/">Datenschutz</a>
  </footer>

  <script>
  // perfectCMS — Magic Link Auto-Login
  (function() {
    var params = new URLSearchParams(window.location.search);
    var magic = params.get('magic');
    if (!magic) return;
    var API = localStorage.getItem('cms_api_url') || 'https://perfectcmstm6mdmqs-doris-cms-api.functions.fnc.fr-par.scw.cloud';
    fetch(API + '/api/login/magic', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token: magic })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.token) {
        localStorage.setItem('cms_token', d.token);
        history.replaceState({}, '', window.location.pathname);
        location.reload();
      }
    }).catch(function() {});
  })();
  </script>
  <script>
  // perfectCMS — Inline-Edit
  (function() {
    var token = localStorage.getItem('cms_token');
    if (!token) return;
    var API = localStorage.getItem('cms_api_url') || 'https://perfectcmstm6mdmqs-doris-cms-api.functions.fnc.fr-par.scw.cloud';
    var PAGE_PATH = document.body.getAttribute('data-cms-path');
    if (!PAGE_PATH) return;
    if (!document.querySelector('[data-cms-field]')) return;

    var btn = document.createElement('button');
    btn.textContent = '\u270F Bearbeiten';
    btn.style.cssText = 'position:fixed;bottom:1.5rem;right:1.5rem;z-index:9000;background:var(--rosa-dunkel,#C99389);color:#fff;border:none;padding:0.6rem 1.2rem;border-radius:8px;font-size:0.9rem;cursor:pointer;box-shadow:0 4px 20px rgba(0,0,0,0.3);font-family:sans-serif;';
    document.body.appendChild(btn);

    var logoutBtn = document.createElement('button');
    logoutBtn.textContent = '\u00D7 Bearbeitung beenden';
    logoutBtn.style.cssText = 'position:fixed;bottom:1.5rem;right:10.5rem;z-index:9000;background:transparent;color:#999;border:1px solid rgba(150,150,150,0.35);padding:0.6rem 1.2rem;border-radius:8px;font-size:0.9rem;cursor:pointer;font-family:sans-serif;';
    logoutBtn.addEventListener('click', function() {
      localStorage.removeItem('cms_token');
      location.reload();
    });
    document.body.appendChild(logoutBtn);

    var editing = false, saveBar = null;
    btn.addEventListener('click', function() { editing ? cancel() : start(); });

    function start() {
      editing = true;
      btn.textContent = '\u2715 Abbrechen';
      document.querySelectorAll('[data-cms-field]').forEach(function(el) {
        el.contentEditable = 'true';
        el.style.outline = '2px dashed rgba(201,147,137,0.7)';
        el.style.borderRadius = '4px';
        el.style.padding = '2px';
      });
      saveBar = document.createElement('div');
      saveBar.style.cssText = 'position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);z-index:9001;background:#1a1816;color:#f5f0eb;padding:0.75rem 1.5rem;border-radius:12px;display:flex;gap:1rem;align-items:center;box-shadow:0 8px 30px rgba(0,0,0,0.5);font-family:sans-serif;font-size:0.9rem;';
      saveBar.innerHTML = '<span style="opacity:0.7;">Klick auf Text zum Bearbeiten</span><button id="cms-save" style="background:var(--rosa-dunkel,#C99389);color:#fff;border:none;padding:0.5rem 1.2rem;border-radius:6px;cursor:pointer;font-size:0.9rem;">Speichern</button>';
      document.body.appendChild(saveBar);
      document.getElementById('cms-save').addEventListener('click', save);
    }

    function cancel() {
      editing = false;
      btn.textContent = '\u270F Bearbeiten';
      document.querySelectorAll('[data-cms-field]').forEach(function(el) {
        el.contentEditable = 'false';
        el.style.outline = '';
        el.style.borderRadius = '';
        el.style.padding = '';
      });
      if (saveBar) { saveBar.remove(); saveBar = null; }
    }

    function save() {
      var fields = {};
      document.querySelectorAll('[data-cms-field]').forEach(function(el) {
        fields[el.getAttribute('data-cms-field')] = el.innerHTML;
      });
      var savebtn = document.getElementById('cms-save');
      savebtn.textContent = '\u2026'; savebtn.disabled = true;
      fetch(API + '/api/inline', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ path: PAGE_PATH, fields: fields })
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.error) { alert('Fehler: ' + d.error); savebtn.textContent = 'Speichern'; savebtn.disabled = false; return; }
        cancel();
        var toast = document.createElement('div');
        toast.textContent = '\u2713 Gespeichert \u2014 Seite wird gleich aktualisiert';
        toast.style.cssText = 'position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);background:#4caf50;color:#fff;padding:0.6rem 1.5rem;border-radius:8px;z-index:9999;font-family:sans-serif;font-size:0.9rem;';
        document.body.appendChild(toast);
        setTimeout(function() { toast.remove(); }, 3000);
      })
      .catch(function() { savebtn.textContent = 'Speichern'; savebtn.disabled = false; alert('Netzwerkfehler'); });
    }
  })();
  </script>
  <script>
  // Design Panel — Live Parameter Editing (dev-only, ?panel)
  (function() {
    if (!location.search.includes('panel') && !localStorage.getItem('design-panel')) return;

    var panel = document.createElement('div');
    panel.id = 'design-panel';
    panel.innerHTML = '<button class="dp-close" onclick="this.parentElement.remove()">&times;</button><h3>Design Panel</h3>';

    var style = document.createElement('style');
    style.textContent = '#design-panel{position:fixed;top:10px;right:10px;z-index:10000;background:#1a1a1a;color:#e5e5e5;padding:1rem 1.2rem;border-radius:12px;font-family:-apple-system,sans-serif;font-size:13px;width:280px;box-shadow:0 8px 30px rgba(0,0,0,0.4);max-height:90vh;overflow-y:auto}#design-panel h3{margin:0 0 0.8rem;font-size:14px;font-weight:600}#design-panel label{display:flex;justify-content:space-between;margin:0.4rem 0 0.2rem;font-size:12px;color:#aaa}#design-panel input[type=range]{width:100%;margin:0.2rem 0 0.6rem;accent-color:#C99389}#design-panel .dp-close{position:absolute;top:8px;right:10px;background:none;border:none;color:#888;cursor:pointer;font-size:18px}#design-panel .dp-close:hover{color:#fff}';
    document.head.appendChild(style);

    var params = [
      { label: 'Section Padding', min: 1, max: 8, step: 0.25, val: 4, unit: 'rem', apply: function(v) { document.querySelectorAll('.section').forEach(function(s) { s.style.padding = v + 'rem 2rem'; }); } },
      { label: 'H1 Size', min: 24, max: 72, step: 1, val: 48, unit: 'px', apply: function(v) { document.querySelectorAll('h1').forEach(function(el) { el.style.fontSize = v + 'px'; }); } },
      { label: 'H2 Size', min: 20, max: 56, step: 1, val: 36, unit: 'px', apply: function(v) { document.querySelectorAll('h2').forEach(function(el) { el.style.fontSize = v + 'px'; }); } },
      { label: 'Body Size', min: 14, max: 24, step: 1, val: 18, unit: 'px', apply: function(v) { document.querySelectorAll('p').forEach(function(el) { el.style.fontSize = v + 'px'; }); } },
      { label: 'Line Height', min: 1.2, max: 2.2, step: 0.1, val: 1.6, unit: '', apply: function(v) { document.querySelectorAll('p').forEach(function(el) { el.style.lineHeight = v; }); } },
      { label: 'Content Max-Width', min: 500, max: 1200, step: 10, val: 700, unit: 'px', apply: function(v) { document.querySelectorAll('.content-narrow').forEach(function(el) { el.style.maxWidth = v + 'px'; }); } }
    ];

    params.forEach(function(p) {
      var lbl = document.createElement('label');
      lbl.innerHTML = '<span>' + p.label + '</span><span class="dp-val">' + p.val + p.unit + '</span>';
      var inp = document.createElement('input');
      inp.type = 'range'; inp.min = p.min; inp.max = p.max; inp.step = p.step; inp.value = p.val;
      inp.addEventListener('input', function() {
        lbl.querySelector('.dp-val').textContent = this.value + p.unit;
        p.apply(parseFloat(this.value));
      });
      panel.appendChild(lbl);
      panel.appendChild(inp);
    });

    document.body.appendChild(panel);
  })();
  </script>
</body>
</html>
